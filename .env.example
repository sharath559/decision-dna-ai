# DecisionDNA AI — Environment Configuration
# Copy to .env and customize for private demo mode.
# The app runs fully without .env (PUBLIC_DEMO_MODE).

PROJECT_OWNER="Your Name"
PROJECT_HANDLE="@your-handle"
PROJECT_NAME="DecisionDNA AI"
SCENARIO_SEED="custom-local-seed"

# Demo mode: set PRIVATE_DEMO_MODE=true for personalized synthetic variations.
PUBLIC_DEMO_MODE=true
PRIVATE_DEMO_MODE=false

# Optional: Gemini API key for LLM-backed agents (not required for demo).
# GOOGLE_API_KEY=
