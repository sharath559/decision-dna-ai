# DecisionDNA AI — Environment Configuration (Kaggle Public/Private Demo)
# Copy this file to .env and customize to run in PRIVATE demo mode.
# The application runs fully in PUBLIC mode without .env or .local/ files.

PROJECT_OWNER="Sharath Chandra"
PROJECT_HANDLE="@yakarasharath4"
PROJECT_NAME="DecisionDNA AI"
PROJECT_MODE="PUBLIC"
PRIVATE_DEMO_MODE="false"
SCENARIO_SEED="replace-with-your-local-seed"
SHOW_OWNER_WATERMARK="true"
MOCK_MODE="true"

# --- Google AI Configuration ---
# Set your Google AI Studio API key to enable Gemini 2.0 Flash integration.
# Without this, the system runs in deterministic MOCK_MODE (fully functional).
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=""

# Optional: Use Vertex AI instead of AI Studio
# GOOGLE_GENAI_USE_VERTEXAI="false"
# GOOGLE_CLOUD_PROJECT=""
# GOOGLE_CLOUD_LOCATION="us-central1"
